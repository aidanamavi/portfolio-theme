{
  "name": "portfolio-theme",
  "version": "0.5.0",
  "description": "A minimalist WordPress theme for portfolios",
  "main": "js/base.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint:js": "eslint js/**/*.js",
    "lint:fix": "eslint js/**/*.js --fix"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "babel-jest": "^29.0.0",
    "eslint": "^8.30.0",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^29.0.0",
    "jquery": "^3.7.1"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": [
      "<rootDir>/tests/js/setup.js"
    ],
    "testMatch": [
      "**/tests/js/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "js/**/*.js",
      "!js/jquery.min.js",
      "!js/**/*.min.js"
    ]
  },
  "babel": {
    "presets": [
      "@babel/preset-env"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aidanamavi/portfolio-theme.git"
  },
  "author": "Aidan Amavi <mail@aidanamavi.com>",
  "license": "AGPL-3.0-or-later"
}
